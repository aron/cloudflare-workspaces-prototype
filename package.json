{
  "name": "cloudflare-workspaces",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build":     "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev":       "npm run dev    --workspace=@app/agent",
    "deploy":    "npm run deploy --workspace=@app/agent"
  }
}
