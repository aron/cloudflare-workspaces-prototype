{
  "name": "@app/agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0",
    "predeploy": "bash sandbox/sync-host-ca.sh && npm run build --workspace=@cloudflare/workspace && npm run build --workspace=@app/frontend",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/agent-suite/tsconfig.json",
    "test": "vitest run && vitest run --config tests/agent-suite/vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "skills:sync": "node scripts/sync-skills.mjs",
    "skills:sync:local": "node scripts/sync-skills.mjs --local"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@app/shared": "*",
    "@cloudflare/ai-chat": "^0.7.1",
    "@cloudflare/containers": "^0.3.4",
    "@cloudflare/fs-tools": "*",
    "@cloudflare/git-tools": "*",
    "@cloudflare/sandbox": "^0.9.2",
    "@cloudflare/shell": "^0.3.8",
    "@cloudflare/think": "^0.7.2",
    "@cloudflare/web-tools": "*",
    "@cloudflare/workspace": "*",
    "acorn": "^8.16.0",
    "agents": "^0.13.2",
    "ai": "^6.0.188",
    "hono": "^4.12.22",
    "jose": "^6.2.3",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.7",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@types/ws": "^8.18.1",
    "rolldown": "^1.0.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.14.0",
    "ws": "^8.21.0"
  }
}
