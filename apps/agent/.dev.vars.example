# Copy this file to .dev.vars and fill in the values.
# .dev.vars is gitignored so secrets stay local.

# --- model selection ---
# If OPENAI_API_KEY is set, the agent uses OpenAI; otherwise falls back to Workers AI.
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.5
# OPENAI_REASONING_EFFORT=medium    # one of: none, minimal, low, medium, high, xhigh

# --- deploy ---
# Only needed if you want to run `npx wrangler` commands locally without `wrangler login`.
# CLOUDFLARE_API_TOKEN=

# --- web search ---
# Optional: enables the websearch tool. Get a key at https://api-dashboard.search.brave.com/
# BRAVE_API_KEY=

# --- identity (local dev) ---
# When Access is not configured (ACCESS_TEAM_DOMAIN / ACCESS_AUD unset), the
# worker falls back to this dev identity so `wrangler dev` keeps working.
# Leave unset to use the hardcoded "Local Dev" user.
# ACCESS_DEV_USER={"userId":"u-venkman","email":"venkman@example.com","name":"Venkman"}

# --- notifications ---
# Optional: Google Chat incoming-webhook URL. When set, the Room DO fires a
# ping at this webhook whenever a message contains a `<user:ID>` mention of
# a user who has saved their Google Workspace user ID in Settings.
# GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...&token=...

# --- public origin ---
# Used to build absolute URLs in agent messages and Google Chat pings.
# When unset the worker derives the origin from the inbound request and
# forwards it to DOs via the `x-app-base-url` header.
# APP_BASE_URL=http://localhost:8787
