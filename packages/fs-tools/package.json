{
  "name": "@cloudflare/fs-tools",
  "version": "0.1.0",
  "type": "module",
  "description": "Memory-efficient read/write/edit AI tools backed by a pluggable FileStore. Designed for Cloudflare Workers and Durable Objects.",
  "exports": {
    ".":          { "import": "./src/index.ts",         "types": "./src/index.ts" },
    "./store":    { "import": "./src/stores/index.ts",  "types": "./src/stores/index.ts" }
  },
  "files": ["src/", "README.md"],
  "scripts": {
    "test":      "vitest run",
    "test:watch":"vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/node": "^20.0.0",
    "ai":          "^6.0.188",
    "typescript":  "^5.7.0",
    "vitest":      "^2.1.9"
  }
}
