{
  "name": "@cloudflare/workspace",
  "version": "0.1.0",
  "type": "module",
  "description": "Durable-Object-backed virtual filesystem that syncs with a Cloudflare Sandbox container and runs WASM via Dynamic Workers.",
  "exports": {
    ".":                    { "import": "./dist/index.js",          "types": "./dist/index.d.ts" },
    "./worker-sandbox":     { "import": "./dist/worker-sandbox.js", "types": "./dist/worker-sandbox/index.d.ts" },
    "./container-sandbox":  { "default": "./dist/container-sandbox.cjs" },
    "./shared":             { "import": "./dist/shared.js",         "types": "./dist/shared/index.d.ts" },
    "./git":                { "import": "./dist/git.js",            "types": "./dist/git.d.ts" }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build:runner": "node src/worker-sandbox/build.mjs",
    "build:types":  "tsc -p tsconfig.types.json",
    "build":        "npm run build:runner && node scripts/build.mjs && npm run build:types",
    "typecheck":    "tsc --noEmit",
    "test":         "node --import tsx --import ./tests/setup.ts --test tests/*.test.ts"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.4",
    "@cloudflare/sandbox":    "^0.9.2",
    "capnweb":                "^0.6.1",
    "isomorphic-git":         "^1.38.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@types/node":               "^20.0.0",
    "@types/ws":                 "^8.18.1",
    "esbuild":                   "^0.25.0",
    "typescript":                "^5.7.0",
    "tsx":                       "^4.19.0",
    "ws":                        "^8.20.0"
  },
  "optionalDependencies": {
    "fuse-native": "^2.2.6"
  },
  "peerDependencies": {
    "@cloudflare/sandbox": "^0.9.2"
  }
}
