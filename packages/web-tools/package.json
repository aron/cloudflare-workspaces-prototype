{
  "name": "@cloudflare/web-tools",
  "version": "0.1.0",
  "type": "module",
  "description": "Memory-efficient webFetch AI tool that returns markdown. Uses Accept: text/markdown first, then falls back to Workers AI for HTML conversion.",
  "exports": {
    ".": { "import": "./src/index.ts", "types": "./src/index.ts" }
  },
  "files": ["src/", "README.md"],
  "scripts": {
    "test":      "vitest run",
    "test:watch":"vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ai":          "^6.0.188",
    "typescript":  "^5.7.0",
    "vitest":      "^4.1.0"
  }
}
